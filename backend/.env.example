# Used by `manage.py runserver` run natively (config.settings.dev, SQLite).
# Postgres/settings-module vars for `docker compose up` still live in
# ../docker-compose.yml, NOT here — but that file also loads backend/.env via
# `env_file` for optional overrides (ej. email/Resend) that don't belong
# hardcoded in a committed file. backend/.env is gitignored either way.
SECRET_KEY=django-insecure-change-this-in-production-use-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (leave blank to use SQLite in dev)
DB_NAME=flowdesk
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Frontend origin for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AppSheet / Google Sheets sync (leave blank to disable sync_appsheet)
# GOOGLE_SHEETS_CREDENTIALS_JSON: full JSON key of a Google Cloud service
# account with the Sheets API enabled, shared as Editor on the target sheet.
GOOGLE_SHEETS_CREDENTIALS_JSON=
APPSHEET_SPREADSHEET_ID=
APPSHEET_WORKSHEET_NAME=

# Email transaccional (signup: verificación, reset de contraseña).
# Deja EMAIL_BACKEND en blanco para usar la consola (los correos se imprimen
# en la terminal de runserver — nada de esto es necesario para desarrollar).
# Envío real: Postmark con el dominio nexoengine.tech (DKIM + Return-Path
# verificados en el DNS de Hostinger). OJO: una cuenta nueva de Postmark está
# en "test mode" hasta que la aprueben — solo entrega a correos del mismo
# dominio del remitente.
# EMAIL_BACKEND=anymail.backends.postmark.EmailBackend
# DEFAULT_FROM_EMAIL=Nexo <no-reply@nexoengine.tech>
# POSTMARK_SERVER_TOKEN=...
EMAIL_BACKEND=
DEFAULT_FROM_EMAIL=Nexo <no-reply@nexoengine.tech>
FRONTEND_URL=http://localhost:8080
POSTMARK_SERVER_TOKEN=
RESEND_API_KEY=
