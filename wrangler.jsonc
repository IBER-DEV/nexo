{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nexo",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "workers_dev": true,
  "routes": [
    { "pattern": "nexoengine.tech/*", "zone_name": "nexoengine.tech" },
    { "pattern": "www.nexoengine.tech/*", "zone_name": "nexoengine.tech" }
  ],
}
